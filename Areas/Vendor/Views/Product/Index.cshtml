@using ECommerceApplication.Models
@model IEnumerable<Product>
@{
    ViewData["Title"] = "My Products";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="bi bi-box-seam me-2"></i>My Products</h4>
    <a asp-action="Create" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i>Add Product
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Product</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    var mainImg = p.Images.FirstOrDefault(i => i.IsMain) ?? p.Images.FirstOrDefault();
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                @if (mainImg is not null)
                                {
                                    <img src="@mainImg.ImageUrl" class="rounded" width="40" height="40"
                                         style="object-fit:cover" alt="@p.Name" />
                                }
                                else
                                {
                                    <div class="rounded bg-light d-flex align-items-center justify-content-center"
                                         style="width:40px;height:40px">
                                        <i class="bi bi-image text-muted"></i>
                                    </div>
                                }
                                <span class="fw-semibold">@p.Name</span>
                            </div>
                        </td>
                        <td><span class="badge bg-light text-dark border">@p.Category.Name</span></td>
                        <td>$@p.Price.ToString("N2")</td>
                        <td>
                            <span class="badge @(p.StockQuantity < 5 ? "bg-danger" : p.StockQuantity < 20 ? "bg-warning text-dark" : "bg-success")">
                                @p.StockQuantity
                            </span>
                        </td>
                        <td>
                            <span class="badge @(p.IsActive ? "bg-success" : "bg-secondary")">
                                @(p.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-secondary me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@p.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Delete @p.Name?')">
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-5">
                            <i class="bi bi-box-seam display-4 d-block mb-2"></i>
                            No products yet.
                            <a asp-action="Create" class="d-block mt-2">Add your first product →</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
