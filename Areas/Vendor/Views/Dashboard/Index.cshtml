@{
    ViewData["Title"] = "Vendor Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">My Dashboard</h4>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 bg-primary bg-opacity-10 p-3">
                    <i class="bi bi-box-seam fs-3 text-primary"></i>
                </div>
                <div>
                    <div class="text-muted small">My Products</div>
                    <div class="fs-4 fw-bold">@ViewBag.TotalProducts</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 bg-success bg-opacity-10 p-3">
                    <i class="bi bi-receipt fs-3 text-success"></i>
                </div>
                <div>
                    <div class="text-muted small">Orders</div>
                    <div class="fs-4 fw-bold">@ViewBag.TotalOrders</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 bg-warning bg-opacity-10 p-3">
                    <i class="bi bi-currency-dollar fs-3 text-warning"></i>
                </div>
                <div>
                    <div class="text-muted small">Revenue</div>
                    <div class="fs-4 fw-bold">$@ViewBag.TotalRevenue.ToString("N2")</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 bg-danger bg-opacity-10 p-3">
                    <i class="bi bi-exclamation-triangle fs-3 text-danger"></i>
                </div>
                <div>
                    <div class="text-muted small">Low Stock</div>
                    <div class="fs-4 fw-bold">@ViewBag.LowStock</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <a asp-area="Vendor" asp-controller="Product" asp-action="Create"
           class="card border-0 shadow-sm text-decoration-none text-dark h-100">
            <div class="card-body text-center py-4">
                <i class="bi bi-plus-circle display-5 text-primary mb-2"></i>
                <h6>Add New Product</h6>
            </div>
        </a>
    </div>
    <div class="col-md-6">
        <a asp-area="Vendor" asp-controller="Product" asp-action="Index"
           class="card border-0 shadow-sm text-decoration-none text-dark h-100">
            <div class="card-body text-center py-4">
                <i class="bi bi-list-ul display-5 text-success mb-2"></i>
                <h6>View My Products</h6>
            </div>
        </a>
    </div>
</div>
