@model IEnumerable<Category>
@{
    ViewData["Title"] = "Categories";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="bi bi-tags me-2"></i>Categories</h4>
    <a asp-action="Create" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i>New Category
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th>Products</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>

                @foreach (var parent in Model)
                {
                    <!-- Parent Row -->
                    <tr class="table-primary">
                        <td class="fw-bold">
                            <i class="bi bi-folder2 me-1"></i>
                            @parent.Name
                        </td>
                        <td>
                            <span class="badge bg-info text-dark">
                                @parent.Products.Count
                            </span>
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@parent.Id"
                               class="btn btn-sm btn-outline-secondary me-1">
                                <i class="bi bi-pencil"></i>
                            </a>

                            <form asp-action="Delete" asp-route-id="@parent.Id"
                                  method="post" class="d-inline"
                                  onsubmit="return confirm('Delete @parent.Name?')">
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>

                    <!-- SubCategories -->
                    @foreach (var child in parent.SubCategories)
                    {
                        <tr>
                            <td class="ps-5">
                                <i class="bi bi-arrow-return-right me-2 text-muted"></i>
                                @child.Name
                            </td>
                            <td>
                                <span class="badge bg-info text-dark">
                                    @child.Products.Count
                                </span>
                            </td>
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@child.Id"
                                   class="btn btn-sm btn-outline-secondary me-1">
                                    <i class="bi bi-pencil"></i>
                                </a>

                                <form asp-action="Delete" asp-route-id="@child.Id"
                                      method="post" class="d-inline"
                                      onsubmit="return confirm('Delete @child.Name?')">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }

                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="3" class="text-center text-muted py-4">
                            No categories yet.
                        </td>
                    </tr>
                }

            </tbody>
        </table>
    </div>
</div>