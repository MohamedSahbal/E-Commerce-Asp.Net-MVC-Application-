@model Product
@{
    ViewData["Title"] = Model.Name;
}

<div class="d-flex align-items-center gap-2 mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
    <h4 class="mb-0">@Model.Name</h4>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary ms-auto">
        <i class="bi bi-pencil me-1"></i>Edit
    </a>
</div>

<div class="row g-4">
    <div class="col-md-5">
        @{
            var images = Model.Images.ToList();
            var main = images.FirstOrDefault(i => i.IsMain) ?? images.FirstOrDefault();
        }
        @if (main is not null)
        {
            <img src="@main.ImageUrl" class="img-fluid rounded shadow-sm w-100" style="object-fit:cover;max-height:350px" alt="@Model.Name" />
            @if (images.Count > 1)
            {
                <div class="d-flex gap-2 mt-2 flex-wrap">
                    @foreach (var img in images)
                    {
                        <img src="@img.ImageUrl" class="rounded border @(img.IsMain ? "border-primary border-2" : "")"
                             width="60" height="60" style="object-fit:cover;cursor:pointer" alt="" />
                    }
                </div>
            }
        }
        else
        {
            <div class="bg-light rounded d-flex align-items-center justify-content-center" style="height:250px">
                <i class="bi bi-image display-3 text-muted"></i>
            </div>
        }
    </div>

    <div class="col-md-7">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Category</dt>
                    <dd class="col-sm-8">@Model.Category.Name</dd>
                    <dt class="col-sm-4">Vendor</dt>
                    <dd class="col-sm-8">@Model.Vendor.Email</dd>
                    <dt class="col-sm-4">Price</dt>
                    <dd class="col-sm-8 fw-bold fs-5 text-primary">$@Model.Price.ToString("N2")</dd>
                    <dt class="col-sm-4">Stock</dt>
                    <dd class="col-sm-8">@Model.StockQuantity units</dd>
                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">
                        <span class="badge @(Model.IsActive ? "bg-success" : "bg-secondary")">
                            @(Model.IsActive ? "Active" : "Inactive")
                        </span>
                    </dd>
                    <dt class="col-sm-4">Created</dt>
                    <dd class="col-sm-8">@Model.CreatedAt.ToString("MMM dd, yyyy")</dd>
                </dl>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.Description))
        {
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-transparent fw-semibold">Description</div>
                <div class="card-body">@Model.Description</div>
            </div>
        }

        @if (Model.Reviews.Any())
        {
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-transparent fw-semibold">
                    Reviews (@Model.Reviews.Count)
                    <span class="ms-2 text-warning">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <i class="bi bi-star@(i <= Math.Round(Model.Reviews.Average(r => r.Rating)) ? "-fill" : "")"></i>
                        }
                    </span>
                    <span class="ms-1 small text-muted">@Model.Reviews.Average(r => r.Rating).ToString("F1")</span>
                </div>
                <div class="list-group list-group-flush">
                    @foreach (var review in Model.Reviews.Take(5))
                    {
                        <div class="list-group-item">
                            <div class="d-flex justify-content-between">
                                <span class="fw-semibold small">@review.Customer.Email</span>
                                <span class="text-warning small">@string.Concat(Enumerable.Repeat("★", review.Rating))</span>
                            </div>
                            <p class="mb-0 small text-muted">@review.Comment</p>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>
