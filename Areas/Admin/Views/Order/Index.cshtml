@model IEnumerable<Order>
@{
    ViewData["Title"] = "All Orders";
    var statuses = Enum.GetValues<OrderStatus>();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="bi bi-bag-check me-2"></i>Orders</h4>
    <span class="badge bg-secondary fs-6">@Model.Count() total</span>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
        <div class="d-flex flex-wrap gap-2 align-items-center">
            <span class="text-muted small me-1">Filter by status:</span>
            <a asp-action="Index" class="btn btn-sm @(ViewBag.StatusFilter == null ? "btn-dark" : "btn-outline-secondary")">All</a>
            @foreach (var s in statuses)
            {
                <a asp-action="Index" asp-route-status="@s"
                   class="btn btn-sm @(ViewBag.StatusFilter == s.ToString() ? "btn-dark" : "btn-outline-secondary")">
                    @s
                </a>
            }
        </div>
    </div>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-bag display-3 mb-3 d-block"></i>
        <p>No orders found.</p>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Order</th>
                        <th>Customer</th>
                        <th>Date</th>
                        <th>Items</th>
                        <th>Total</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in Model)
                    {
                        <tr>
                            <td class="fw-semibold">#@o.Id</td>
                            <td>@o.Customer.FirstName @o.Customer.LastName<br /><small class="text-muted">@o.Customer.Email</small></td>
                            <td class="text-muted small">@o.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td>@o.OrderItems.Sum(i => i.Quantity)</td>
                            <td class="fw-bold">$@o.Total.ToString("N2")</td>
                            <td>
                                @{
                                    var (bg, icon) = o.Status switch
                                    {
                                        OrderStatus.Pending => ("bg-warning text-dark", "bi-hourglass"),
                                        OrderStatus.Processing => ("bg-info text-dark", "bi-gear"),
                                        OrderStatus.Shipped => ("bg-primary", "bi-truck"),
                                        OrderStatus.Delivered => ("bg-success", "bi-check-circle"),
                                        OrderStatus.Cancelled => ("bg-danger", "bi-x-circle"),
                                        _ => ("bg-secondary", "bi-circle")
                                    };
                                }
                                <span class="badge @bg"><i class="bi @icon me-1"></i>@o.Status</span>
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@o.Id"
                                   class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
