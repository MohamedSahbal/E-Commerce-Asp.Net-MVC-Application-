@model Order
@{
    ViewData["Title"] = $"Order #{Model.Id}";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var statuses = Enum.GetValues<OrderStatus>();
    var (bg, icon) = Model.Status switch
    {
        OrderStatus.Pending => ("bg-warning text-dark", "bi-hourglass"),
        OrderStatus.Processing => ("bg-info text-dark", "bi-gear"),
        OrderStatus.Shipped => ("bg-primary", "bi-truck"),
        OrderStatus.Delivered => ("bg-success", "bi-check-circle"),
        OrderStatus.Cancelled => ("bg-danger", "bi-x-circle"),
        _ => ("bg-secondary", "bi-circle")
    };
}

<div class="d-flex align-items-center gap-2 mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
    <h4 class="mb-0">Order #@Model.Id</h4>
    <span class="badge @bg"><i class="bi @icon me-1"></i>@Model.Status</span>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-transparent fw-semibold">Items</div>
            @foreach (var item in Model.OrderItems)
            {
                var img = item.Product.Images.FirstOrDefault(i => i.IsMain) ?? item.Product.Images.FirstOrDefault();
                <div class="d-flex align-items-center gap-3 p-3 @(item != Model.OrderItems.Last() ? "border-bottom" : "")">
                    @if (img is not null)
                    {
                        <img src="@img.ImageUrl" class="rounded" style="width:60px;height:60px;object-fit:cover" alt="@item.Product.Name" />
                    }
                    else
                    {
                        <div class="rounded bg-light d-flex align-items-center justify-content-center" style="width:60px;height:60px">
                            <i class="bi bi-image text-muted"></i>
                        </div>
                    }
                    <div class="flex-grow-1">
                        <div class="fw-semibold">@item.Product.Name</div>
                        <div class="text-muted small">
                            Vendor: @item.Vendor.FirstName @item.Vendor.LastName &bull;
                            Qty: @item.Quantity &bull; $@item.UnitPrice.ToString("N2") each
                        </div>
                    </div>
                    <div class="fw-bold">$@((item.UnitPrice * item.Quantity).ToString("N2"))</div>
                </div>
            }
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent fw-semibold">Update Status</div>
            <div class="card-body">
                <form asp-action="UpdateStatus" method="post" class="d-flex align-items-center gap-2">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <select name="status" class="form-select w-auto">
                        @foreach (var s in statuses)
                        {
                            if (s == Model.Status)
                            {
                                <option value="@s" selected>@s</option>
                            }
                            else
                            {
                                <option value="@s">@s</option>
                            }
                        }
                    </select>
                    <button type="submit" class="btn btn-dark">Update</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-transparent fw-semibold">Customer</div>
            <div class="card-body small">
                <div class="fw-semibold">@Model.Customer.FirstName @Model.Customer.LastName</div>
                <div class="text-muted">@Model.Customer.Email</div>
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-transparent fw-semibold">Summary</div>
            <div class="card-body small">
                <div class="d-flex justify-content-between mb-1">
                    <span class="text-muted">Subtotal</span>
                    <span>$@Model.SubTotal.ToString("N2")</span>
                </div>
                @if (Model.DiscountAmount > 0)
                {
                    <div class="d-flex justify-content-between mb-1 text-success">
                        <span>Discount @(Model.Promotion is not null ? $"({Model.Promotion.Code})" : "")</span>
                        <span>-$@Model.DiscountAmount.ToString("N2")</span>
                    </div>
                }
                <div class="d-flex justify-content-between fw-bold border-top pt-2">
                    <span>Total</span>
                    <span>$@Model.Total.ToString("N2")</span>
                </div>
                @if (Model.StripePaymentIntentId is not null)
                {
                    <div class="text-muted mt-2 border-top pt-2">
                        <i class="bi bi-credit-card me-1"></i>@Model.StripePaymentIntentId
                    </div>
                }
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent fw-semibold">Shipping Address</div>
            <div class="card-body text-muted small">@Model.ShippingAddress</div>
        </div>
    </div>
</div>
