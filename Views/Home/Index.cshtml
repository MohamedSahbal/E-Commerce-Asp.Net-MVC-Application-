@{
    ViewData["Title"] = "Home";
    var featured = ViewBag.FeaturedProducts as List<Product> ?? new();
    var categories = ViewBag.TopCategories as List<Category> ?? new();
}

<div class="p-5 mb-4 bg-dark text-white rounded-3 position-relative overflow-hidden">
    <div class="container-fluid py-2 position-relative" style="z-index:1">
        <h1 class="display-5 fw-bold">
            <i class="bi bi-bag-heart-fill me-2"></i>Welcome to Dreams Shop
        </h1>
        <p class="col-md-7 fs-5 text-white-50">
         Make your Dreams come true , Discover thousands of products from trusted vendors. Secure payments, genuine reviews, Competitive prices, fast shipping.
        </p>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-controller="Shop" asp-action="Index" class="btn btn-primary btn-lg">
                <i class="bi bi-grid me-1"></i>Browse All Products
            </a>
            @if (!User.Identity!.IsAuthenticated)
            {
                <a asp-controller="Account" asp-action="Register" class="btn btn-outline-light btn-lg">
                    <i class="bi bi-shop me-1"></i>Start Selling
                </a>
            }
        </div>
        @if ((int)ViewBag.TotalProducts > 0)
        {
            <div class="d-flex gap-4 mt-4">
                <div>
                    <div class="fs-4 fw-bold text-white">@ViewBag.TotalProducts+</div>
                    <div class="text-white-50 small">Products</div>
                </div>
                <div>
                    <div class="fs-4 fw-bold text-white">@ViewBag.TotalVendors+</div>
                    <div class="text-white-50 small">Vendors</div>
                </div>
            </div>
        }
    </div>
</div>

@* Feature pillars *@
<div class="row g-3 mb-5">
    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm text-center p-3">
            <i class="bi bi-shield-check display-5 text-primary mb-2"></i>
            <h6 class="fw-semibold">Secure Payments</h6>
            <p class="text-muted small mb-0">Protected by Stripe's industry-leading security.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm text-center p-3">
            <i class="bi bi-truck display-5 text-primary mb-2"></i>
            <h6 class="fw-semibold">Fast Shipping</h6>
            <p class="text-muted small mb-0">Shipped directly from verified vendors to your door.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm text-center p-3">
            <i class="bi bi-star display-5 text-primary mb-2"></i>
            <h6 class="fw-semibold">Trusted Reviews</h6>
            <p class="text-muted small mb-0">Genuine ratings from verified buyers only.</p>
        </div>
    </div>
</div>

@* Categories *@
@if (categories.Any())
{
    <div class="mb-5">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="mb-0">Shop by Category</h4>
            <a asp-controller="Shop" asp-action="Index" class="btn btn-sm btn-outline-primary">All Categories →</a>
        </div>
        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-6 g-3">
            @foreach (var cat in categories)
            {
                <div class="col">
                    <a asp-controller="Shop" asp-action="Index" asp-route-categoryId="@cat.Id"
                       class="card border-0 shadow-sm text-decoration-none text-body h-100 text-center">
                        <div class="card-body py-3 px-2">
                            <i class="bi bi-folder2 fs-1 text-primary mb-2 d-block"></i>
                            <div class="fw-semibold small">@cat.Name</div>
                            @if (cat.SubCategories.Any())
                            {
                                <div class="text-muted" style="font-size:.7rem">@cat.SubCategories.Count sub-categor@(cat.SubCategories.Count == 1 ? "y" : "ies")</div>
                            }
                        </div>
                    </a>
                </div>
            }
        </div>
    </div>
}

@* Featured products *@
@if (featured.Any())
{
    <div class="mb-5">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="mb-0">New Arrivals</h4>
            <a asp-controller="Shop" asp-action="Index" class="btn btn-sm btn-outline-primary">View All →</a>
        </div>
        <div class="row row-cols-2 row-cols-md-3 row-cols-xl-4 g-3">
            @foreach (var p in featured)
            {
                var img = p.Images.FirstOrDefault(i => i.IsMain) ?? p.Images.FirstOrDefault();
                var avg = p.Reviews.Any() ? p.Reviews.Average(r => r.Rating) : 0;

                <div class="col">
                    <div class="card h-100 border-0 shadow-sm product-card">
                        <a asp-controller="Shop" asp-action="Details" asp-route-id="@p.Id"
                           class="text-decoration-none">
                            <div class="overflow-hidden" style="height:180px">
                                @if (img is not null)
                                {
                                    <img src="@img.ImageUrl" class="card-img-top h-100 w-100"
                                         style="object-fit:contain;transition:transform .3s" alt="@p.Name" />
                                }
                                else
                                {
                                    <div class="bg-light h-100 d-flex align-items-center justify-content-center">
                                        <i class="bi bi-image display-4 text-muted"></i>
                                    </div>
                                }
                            </div>
                        </a>
                        <div class="card-body d-flex flex-column py-2">
                            <p class="text-muted small mb-1">@p.Category.Name</p>
                            <h6 class="mb-1 flex-grow-1">
                                <a asp-controller="Shop"
                                   asp-action="Details"
                                   asp-route-id="@p.Id"
                                   class="text-decoration-none text-body stretched-link">
                                    @p.Name
                                </a>
                            </h6>
                            @if (p.Reviews.Any())
                            {
                                <div class="text-warning mb-1" style="font-size:.75rem">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="bi bi-star@(i <= Math.Round(avg) ? "-fill" : "")"></i>
                                    }
                                    <span class="text-muted ms-1">(@p.Reviews.Count)</span>
                                </div>
                            }
                            <div class="d-flex justify-content-between align-items-center mt-auto">
                                <span class="fw-bold text-primary">$@p.Price.ToString("N2")</span>
                                @if (p.StockQuantity < 5)
                                {
                                    <span class="badge bg-danger" style="font-size:.65rem">@p.StockQuantity left</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

@* CTA for vendors *@
@if (!User.Identity!.IsAuthenticated)
{
    <div class="card bg-primary text-white border-0 shadow mb-4">
        <div class="card-body d-flex flex-wrap justify-content-between align-items-center gap-3 p-4">
            <div>
                <h5 class="mb-1 fw-bold">Sell on Dreams Shop</h5>
                <p class="mb-0 opacity-75">Join our marketplace — reach thousands of customers today.</p>
            </div>
            <a asp-controller="Account" asp-action="Register" class="btn btn-light btn-lg fw-semibold">
                <i class="bi bi-shop me-1"></i>Become a Vendor
            </a>
        </div>
    </div>
}

<style>
    .product-card:hover .card-img-top {
        transform: scale(1.05);
    }

    .product-card {
        transition: box-shadow .2s;
    }

        .product-card:hover {
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.12) !important;
        }
</style>
