@model ShopVM
@{
    ViewData["Title"] = "Shop";
}

<div class="row g-4">

    <!-- Sidebar -->
    <div class="col-lg-3">

        <!-- Search -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <form method="get" asp-controller="Shop" asp-action="Index">
                    <div class="input-group">
                        <input name="search" value="@Model.Search" class="form-control"
                               placeholder="Search products..." />
                        <button class="btn btn-primary" type="submit">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                    @if (Model.CategoryId.HasValue)
                    {
                        <input type="hidden" name="categoryId" value="@Model.CategoryId" />
                    }
                </form>
            </div>
        </div>

        <!-- Categories -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-transparent fw-semibold">Categories</div>
            <div class="list-group list-group-flush">
                <a asp-controller="Shop" asp-action="Index"
                   asp-route-search="@Model.Search"
                   class="list-group-item list-group-item-action d-flex justify-content-between @(Model.CategoryId is null ? "active" : "")">
                    All Products
                </a>
                @foreach (var cat in Model.Categories)
                {
                    <a asp-controller="Shop" asp-action="Index"
                       asp-route-categoryId="@cat.Id"
                       asp-route-search="@Model.Search"
                       class="list-group-item list-group-item-action d-flex justify-content-between align-items-center @(Model.CategoryId == cat.Id ? "active" : "")">
                        <span><i class="bi bi-folder2 me-2"></i>@cat.Name</span>
                    </a>
                    @foreach (var sub in cat.SubCategories.OrderBy(s => s.Name))
                    {
                        <a asp-controller="Shop" asp-action="Index"
                           asp-route-categoryId="@sub.Id"
                           asp-route-search="@Model.Search"
                           class="list-group-item list-group-item-action ps-4 d-flex justify-content-between align-items-center @(Model.CategoryId == sub.Id ? "active" : "")">
                            <span class="text-muted"><i class="bi bi-dash me-1"></i>@sub.Name</span>
                        </a>
                    }
                }
            </div>
        </div>

        <!-- Price filter -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent fw-semibold">Price Range</div>
            <div class="card-body">
                <form method="get" asp-controller="Shop" asp-action="Index">
                    <input type="hidden" name="search" value="@Model.Search" />
                    <input type="hidden" name="categoryId" value="@Model.CategoryId" />
                    <input type="hidden" name="sortBy" value="@Model.SortBy" />
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="form-label small text-muted">Min ($)</label>
                            <input name="minPrice" type="number" min="0" step="1"
                                   value="@Model.MinPrice" class="form-control form-control-sm" placeholder="0" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small text-muted">Max ($)</label>
                            <input name="maxPrice" type="number" min="0" step="1"
                                   value="@Model.MaxPrice" class="form-control form-control-sm" placeholder="Any" />
                        </div>
                    </div>
                    <button type="submit" class="btn btn-sm btn-outline-primary w-100">Apply</button>
                </form>
            </div>
        </div>

    </div>

    <!-- Product grid -->
    <div class="col-lg-9">

        <!-- Toolbar -->
        <div class="d-flex flex-wrap align-items-center justify-content-between mb-3 gap-2">
            <div>
                <span class="text-muted small">
                    @Model.TotalCount product@(Model.TotalCount != 1 ? "s" : "")
                    @if (!string.IsNullOrWhiteSpace(Model.Search))
                    {
                        <span>for "<strong>@Model.Search</strong>"</span>
                    }
                    @if (Model.ActiveCategoryName is not null)
                    {
                        <span>in <strong>@Model.ActiveCategoryName</strong></span>
                    }
                </span>
                @if (Model.CategoryId.HasValue || !string.IsNullOrWhiteSpace(Model.Search) || Model.MinPrice.HasValue || Model.MaxPrice.HasValue)
                {
                    <a asp-controller="Shop" asp-action="Index" class="btn btn-sm btn-link text-danger p-0 ms-2">
                        <i class="bi bi-x-circle me-1"></i>Clear filters
                    </a>
                }
            </div>

            <form method="get" asp-controller="Shop" asp-action="Index" class="d-flex gap-2 align-items-center">
                <input type="hidden" name="search" value="@Model.Search" />
                <input type="hidden" name="categoryId" value="@Model.CategoryId" />
                <input type="hidden" name="minPrice" value="@Model.MinPrice" />
                <input type="hidden" name="maxPrice" value="@Model.MaxPrice" />
                <label class="text-muted small mb-0">Sort:</label>
                @{
                    var activeSortBy = string.IsNullOrEmpty(Model.SortBy) ? "newest" : Model.SortBy;
                }
                <select name="sortBy" class="form-select form-select-sm" style="width:auto"
                        onchange="this.form.submit()">
                    @if (activeSortBy == "newest")
                    {
                        <option value="newest" selected>Newest</option>
                    }
                    else
                    {
                        <option value="newest">Newest</option>
                    }
                    @if (activeSortBy == "price_asc")
                    {
                        <option value="price_asc" selected>Price: Low to High</option>
                    }
                    else
                    {
                        <option value="price_asc">Price: Low to High</option>
                    }
                    @if (activeSortBy == "price_desc")
                    {
                        <option value="price_desc" selected>Price: High to Low</option>
                    }
                    else
                    {
                        <option value="price_desc">Price: High to Low</option>
                    }
                    @if (activeSortBy == "name")
                    {
                        <option value="name" selected>Name A–Z</option>
                    }
                    else
                    {
                        <option value="name">Name A–Z</option>
                    }
                </select>
            </form>
        </div>

        @if (Model.Products.Any())
        {
            <div class="row row-cols-1 row-cols-sm-2 row-cols-xl-3 g-3">
                @foreach (var p in Model.Products)
                {
                    var mainImg = p.Images.FirstOrDefault(i => i.IsMain) ?? p.Images.FirstOrDefault();
                    var avgRating = p.Reviews.Any() ? p.Reviews.Average(r => r.Rating) : 0;
                    var reviewCount = p.Reviews.Count;

                    <div class="col">
                        <div class="card h-100 border-0 shadow-sm product-card position-relative">
                            @if (User.IsInRole("Customer"))
                            {
                                <form asp-controller="Wishlist" asp-action="Toggle" method="post"
                                      class="position-absolute top-0 end-0 m-2" style="z-index:1">
                                    <input type="hidden" name="productId" value="@p.Id" />
                                    <button type="submit"
                                            class="btn btn-sm btn-light rounded-circle shadow-sm"
                                            title="Wishlist">
                                        <i class="bi bi-heart text-danger"></i>
                                    </button>
                                </form>
                            }
                            <a asp-controller="Shop" asp-action="Details" asp-route-id="@p.Id"
                               class="text-decoration-none">
                                <div class="overflow-hidden" style="height:200px">
                                    @if (mainImg is not null)
                                    {
                                        <img src="@mainImg.ImageUrl" class="card-img-top h-100 w-100"
                                             style="object-fit:cover;transition:transform .3s"
                                             alt="@p.Name" />
                                    }
                                    else
                                    {
                                        <div class="bg-light h-100 d-flex align-items-center justify-content-center">
                                            <i class="bi bi-image display-4 text-muted"></i>
                                        </div>
                                    }
                                </div>
                            </a>
                            <div class="card-body d-flex flex-column">
                                <p class="text-muted small mb-1">@p.Category.Name</p>
                                <h6 class="card-title mb-1">
                                    <a asp-controller="Shop" asp-action="Details" asp-route-id="@p.Id"
                                       class="text-decoration-none text-dark stretched-link">
                                        @p.Name
                                    </a>
                                </h6>

                                @if (reviewCount > 0)
                                {
                                    <div class="d-flex align-items-center gap-1 mb-2">
                                        <div class="text-warning" style="font-size:.8rem">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <i class="bi bi-star@(i <= Math.Round(avgRating) ? "-fill" : i - 0.5 <= avgRating ? "-half" : "")"></i>
                                            }
                                        </div>
                                        <span class="text-muted" style="font-size:.75rem">(@reviewCount)</span>
                                    </div>
                                }

                                <div class="mt-auto d-flex justify-content-between align-items-center">
                                    <span class="fw-bold text-primary fs-5">$@p.Price.ToString("N2")</span>
                                    @if (p.StockQuantity < 5)
                                    {
                                        <span class="badge bg-danger">Only @p.StockQuantity left</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success-subtle text-success">In Stock</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Pagination -->
            @if (Model.TotalPages > 1)
            {
                <nav class="mt-4">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(!Model.HasPrev ? "disabled" : "")">
                            <a class="page-link" asp-controller="Shop" asp-action="Index"
                               asp-route-page="@(Model.Page - 1)" asp-route-search="@Model.Search"
                               asp-route-categoryId="@Model.CategoryId" asp-route-sortBy="@Model.SortBy"
                               asp-route-minPrice="@Model.MinPrice" asp-route-maxPrice="@Model.MaxPrice">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>

                        @for (int i = Math.Max(1, Model.Page - 2); i <= Math.Min(Model.TotalPages, Model.Page + 2); i++)
                        {
                            <li class="page-item @(i == Model.Page ? "active" : "")">
                                <a class="page-link" asp-controller="Shop" asp-action="Index"
                                   asp-route-page="@i" asp-route-search="@Model.Search"
                                   asp-route-categoryId="@Model.CategoryId" asp-route-sortBy="@Model.SortBy"
                                   asp-route-minPrice="@Model.MinPrice" asp-route-maxPrice="@Model.MaxPrice">
                                    @i
                                </a>
                            </li>
                        }

                        <li class="page-item @(!Model.HasNext ? "disabled" : "")">
                            <a class="page-link" asp-controller="Shop" asp-action="Index"
                               asp-route-page="@(Model.Page + 1)" asp-route-search="@Model.Search"
                               asp-route-categoryId="@Model.CategoryId" asp-route-sortBy="@Model.SortBy"
                               asp-route-minPrice="@Model.MinPrice" asp-route-maxPrice="@Model.MaxPrice">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            }
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-search display-3 text-muted mb-3 d-block"></i>
                <h5>No products found</h5>
                <p class="text-muted">Try adjusting your filters or search term.</p>
                <a asp-controller="Shop" asp-action="Index" class="btn btn-primary">View all products</a>
            </div>
        }

    </div>
</div>

<style>
    .product-card:hover .card-img-top {
        transform: scale(1.05);
    }

    .product-card {
        transition: box-shadow .2s;
    }

        .product-card:hover {
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.12) !important;
        }
</style>
