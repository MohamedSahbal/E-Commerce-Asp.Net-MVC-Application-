@model IEnumerable<Order>
@{
    ViewData["Title"] = "My Orders";
}

<h4 class="mb-4"><i class="bi bi-bag me-2"></i>My Orders</h4>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-bag display-2 text-muted mb-3 d-block"></i>
        <h5>No orders yet</h5>
        <a asp-controller="Shop" asp-action="Index" class="btn btn-primary mt-2">Start Shopping</a>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Order</th>
                        <th>Date</th>
                        <th>Items</th>
                        <th>Total</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in Model)
                    {
                        <tr>
                            <td class="fw-semibold">#@o.Id</td>
                            <td class="text-muted small">@o.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td>@o.OrderItems.Sum(i => i.Quantity) item(s)</td>
                            <td class="fw-bold text-primary">$@o.Total.ToString("N2")</td>
                            <td>
                                @{
                                    var (bg, icon) = o.Status switch
                                    {
                                        OrderStatus.Pending     => ("bg-warning text-dark", "bi-hourglass"),
                                        OrderStatus.Processing  => ("bg-info text-dark",    "bi-gear"),
                                        OrderStatus.Shipped     => ("bg-primary",           "bi-truck"),
                                        OrderStatus.Delivered   => ("bg-success",           "bi-check-circle"),
                                        OrderStatus.Cancelled   => ("bg-danger",            "bi-x-circle"),
                                        _                                            => ("bg-secondary",         "bi-circle")
                                    };
                                }
                                <span class="badge @bg">
                                    <i class="bi @icon me-1"></i>@o.Status
                                </span>
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@o.Id"
                                   class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-eye me-1"></i>Details
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
