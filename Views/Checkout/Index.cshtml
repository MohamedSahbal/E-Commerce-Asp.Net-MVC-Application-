@using ECommerce_Application.ViewModels
@model CheckoutVM
@{
    ViewData["Title"] = "Checkout";
}

<h4 class="mb-4"><i class="bi bi-lock me-2"></i>Checkout</h4>

<form asp-action="PlaceOrder" method="post">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
    <div class="row g-4 align-items-start">

        <!-- Shipping form -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-transparent fw-semibold">
                    <i class="bi bi-geo-alt me-1"></i>Shipping Address
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label"></label>
                        <input asp-for="FullName" class="form-control" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="AddressLine1" class="form-label"></label>
                        <input asp-for="AddressLine1" class="form-control" placeholder="Street address" />
                        <span asp-validation-for="AddressLine1" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="AddressLine2" class="form-label"></label>
                        <input asp-for="AddressLine2" class="form-control" placeholder="Apt, suite, floor (optional)" />
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-5">
                            <label asp-for="City" class="form-label"></label>
                            <input asp-for="City" class="form-control" />
                            <span asp-validation-for="City" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="StateRegion" class="form-label"></label>
                            <input asp-for="StateRegion" class="form-control" />
                            <span asp-validation-for="StateRegion" class="text-danger small"></span>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="PostalCode" class="form-label"></label>
                            <input asp-for="PostalCode" class="form-control" />
                            <span asp-validation-for="PostalCode" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Country" class="form-label"></label>
                            <input asp-for="Country" class="form-control" />
                            <span asp-validation-for="Country" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Phone" class="form-label"></label>
                            <input asp-for="Phone" class="form-control" placeholder="+20 xxx xxxx xxxx" />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Order summary -->
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-transparent fw-semibold">Order Summary</div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush">
                        @foreach (var item in Model.Cart!.Items)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center px-3">
                                <div class="d-flex align-items-center gap-2">
                                    <span class="badge bg-secondary">@item.Quantity</span>
                                    <span class="small">@item.ProductName</span>
                                </div>
                                <span class="small fw-semibold">$@item.LineTotal.ToString("N2")</span>
                            </li>
                        }
                    </ul>
                </div>
                <div class="card-footer bg-transparent">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted small">Subtotal</span>
                        <span class="small">$@Model.Cart.SubTotal.ToString("N2")</span>
                    </div>
                    @if (Model.Cart.AppliedPromotion is not null)
                    {
                        <div class="d-flex justify-content-between mb-1 text-success">
                            <span class="small">Discount <code class="ms-1">@Model.Cart.AppliedPromotion.Code</code></span>
                            <span class="small">-$@Model.Cart.DiscountAmount.ToString("N2")</span>
                        </div>
                    }
                    <div class="d-flex justify-content-between fw-bold border-top pt-2">
                        <span>Total</span>
                        <span class="text-primary fs-5">$@Model.Cart.Total.ToString("N2")</span>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body text-center text-muted small py-2">
                    <i class="bi bi-lock-fill me-1 text-success"></i>
                    Secured by <strong>Stripe</strong>. We never store card details.
                </div>
            </div>

            <button type="submit" class="btn btn-primary w-100 btn-lg">
                <i class="bi bi-credit-card me-2"></i>Pay $@Model.Cart.Total.ToString("N2")
            </button>
            <a asp-controller="Cart" asp-action="Index" class="btn btn-link w-100 mt-1 text-muted">
                <i class="bi bi-arrow-left me-1"></i>Back to Cart
            </a>
        </div>

    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
