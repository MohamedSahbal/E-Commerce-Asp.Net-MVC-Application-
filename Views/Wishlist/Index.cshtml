@model IEnumerable<WishlistItem>
@{
    ViewData["Title"] = "My Wishlist";
    var items = Model.ToList();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">
        <i class="bi bi-heart-fill text-danger me-2"></i>My Wishlist
        <span class="badge bg-secondary ms-1">@items.Count</span>
    </h4>
    @if (items.Any())
    {
        <form asp-action="Clear" method="post"
              onsubmit="return confirm('Remove all items from your wishlist?')">
            <button type="submit" class="btn btn-sm btn-outline-danger">
                <i class="bi bi-trash me-1"></i>Clear All
            </button>
        </form>
    }
</div>

@if (!items.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-heart display-2 text-muted mb-3 d-block"></i>
        <h5>Your wishlist is empty</h5>
        <p class="text-muted">Save products you love and come back to them later.</p>
        <a asp-controller="Shop" asp-action="Index" class="btn btn-primary">
            <i class="bi bi-grid me-1"></i>Browse Products
        </a>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var item in items)
        {
            var product = item.Product;
            var mainImg = product.Images.FirstOrDefault(i => i.IsMain) ?? product.Images.FirstOrDefault();
            var avgRating = product.Reviews.Any() ? product.Reviews.Average(r => r.Rating) : 0;
            var inStock = product.StockQuantity > 0;

            <div class="col-12">
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <div class="row g-3 align-items-center">

                            <!-- Image -->
                            <div class="col-auto">
                                <a asp-controller="Shop" asp-action="Details" asp-route-id="@product.Id">
                                    @if (mainImg is not null)
                                    {
                                        <img src="@mainImg.ImageUrl" class="rounded"
                                             style="width:90px;height:90px;object-fit:cover" alt="@product.Name" />
                                    }
                                    else
                                    {
                                        <div class="rounded bg-light d-flex align-items-center justify-content-center"
                                             style="width:90px;height:90px">
                                            <i class="bi bi-image text-muted fs-3"></i>
                                        </div>
                                    }
                                </a>
                            </div>

                            <!-- Info -->
                            <div class="col">
                                <p class="text-muted small mb-1">@product.Category.Name</p>
                                <h6 class="mb-1">
                                    <a asp-controller="Shop" asp-action="Details" asp-route-id="@product.Id"
                                       class="text-decoration-none text-dark">
                                        @product.Name
                                    </a>
                                </h6>

                                @if (product.Reviews.Any())
                                {
                                    <div class="d-flex align-items-center gap-1 mb-1">
                                        <span class="text-warning" style="font-size:.8rem">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <i class="bi bi-star@(i <= Math.Round(avgRating) ? "-fill" : "")"></i>
                                            }
                                        </span>
                                        <span class="text-muted small">(@product.Reviews.Count)</span>
                                    </div>
                                }

                                <div class="d-flex align-items-center gap-2">
                                    <span class="fw-bold text-primary fs-5">$@product.Price.ToString("N2")</span>
                                    @if (!inStock)
                                    {
                                        <span class="badge bg-secondary">Out of Stock</span>
                                    }
                                    else if (product.StockQuantity < 5)
                                    {
                                        <span class="badge bg-warning text-dark">Only @product.StockQuantity left</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success-subtle text-success">In Stock</span>
                                    }
                                </div>

                                <p class="text-muted small mb-0 mt-1">
                                    Added @item.AddedAt.ToString("MMM dd, yyyy")
                                </p>
                            </div>

                            <!-- Actions -->
                            <div class="col-auto d-flex flex-column gap-2">
                                <form asp-action="MoveToCart" method="post">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit"
                                            class="btn btn-primary btn-sm"
                                        @(!inStock ? "disabled" : "")
                                            title="@(!inStock ? "Out of stock" : "Move to cart")">
                                        <i class="bi bi-cart-plus me-1"></i>Move to Cart
                                    </button>
                                </form>
                                <form asp-action="Remove" method="post">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm w-100">
                                        <i class="bi bi-trash me-1"></i>Remove
                                    </button>
                                </form>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="mt-4 text-end">
        <a asp-controller="Shop" asp-action="Index" class="btn btn-outline-primary">
            <i class="bi bi-grid me-1"></i>Continue Shopping
        </a>
    </div>
}
